# Copie ce fichier en discord_api.env sur la VM (jamais sur GitHub)

# Token bot Discord (Developer Portal)
DISCORD_TOKEN=ton_token_bot_ici

# Cle partagee entre la VM et les clients TOOL OAP
DISCORD_API_KEY=change_cette_cle_secrete

# Ecoute reseau
DISCORD_API_HOST=0.0.0.0
DISCORD_API_PORT=8780

# Dossier publie pour repli SMB (optionnel)
# Windows: C:\Users\Discord\tool_oap
# Linux VPS: /srv/tool_oap
DISCORD_API_PUBLISH_DIR=
