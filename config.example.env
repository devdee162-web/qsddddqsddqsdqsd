# Copie ce fichier en .env et remplis ton token bot Discord
DISCORD_TOKEN=ton_token_bot_ici

# ID de la categorie Discord a exporter
CATEGORY_ID=1520602288635252886

# ID du serveur (optionnel, laisse vide pour auto-detection)
GUILD_ID=

# Salons a exclure (separes par des virgules)
EXCLUDED_CHANNELS=1521941017312362526,1521899575101882499

# Dossier de sortie local
OUTPUT_DIR=export_discord

# Dossiers crees par l'option "Creer un dossier"
DOSSIERS_DIR=dossiers

# Prefixe des salons Discord (ex: 📂william-fourrier)
DOSSIER_PREFIX=📂

# Serveur web local (0.0.0.0 = accessible depuis autres PC du reseau)
WEB_HOST=0.0.0.0
WEB_PORT=8765

# Synchronisation automatique vers VM (partage reseau Windows)
SYNC_VM_ENABLED=true
SYNC_VM_HOST=151.240.100.12
SYNC_VM_USER=Discord
SYNC_VM_PASS=ton_mot_de_passe_vm
SYNC_VM_SHARE=tool_oap
# Ou chemin UNC complet (remplace HOST+SHARE si renseigne) :
# SYNC_VM_UNC=\\151.240.100.12\tool_oap

# Fichier des comptes locaux
ACCOUNTS_FILE=accounts.json

# Mises a jour automatiques via GitHub
GITHUB_REPO=devdee162-web/qsddddqsddqsdqsd
AUTO_UPDATE_ON_START=true
