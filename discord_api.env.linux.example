# discord_api.env pour VPS Linux
# Copie: cp discord_api.env.linux.example discord_api.env

DISCORD_TOKEN=ton_token_bot_ici
DISCORD_API_KEY=change_cette_cle_secrete
DISCORD_API_HOST=0.0.0.0
DISCORD_API_PORT=8780

# Optionnel — dossier du partage Samba tool_oap (repli SMB depuis Windows)
# Exemple si Samba partage /srv/tool_oap :
DISCORD_API_PUBLISH_DIR=/srv/tool_oap
